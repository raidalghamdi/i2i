{
  "buildCommand": "npm run build -- --configuration=production,ar",
  "outputDirectory": "dist/frontend/browser/ar",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://i2i-production.up.railway.app/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
